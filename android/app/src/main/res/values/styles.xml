<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base application theme -->
    <style name="AppTheme" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
        <item name="android:colorAccent">@color/colorAccent</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:navigationBarColor">#FFFFFF</item>
        <item name="android:windowLightNavigationBar">true</item>
        <item name="android:forceDarkAllowed">false</item>
        <item name="android:textColorPrimary">#0B3760</item>
        <item name="android:textColorSecondary">#2F4858</item>
        <item name="android:textColorPrimaryInverse">#FFFFFF</item>
        <item name="android:textColorHighlight">#5571CFC2</item>
        <item name="colorControlNormal">#0B3760</item>
        <item name="android:colorControlNormal">#0B3760</item>
        <item name="actionModeStyle">@style/VetLearnActionMode</item>
        <item name="android:actionModeStyle">@style/VetLearnActionMode</item>
    </style>

    <!-- Main app theme without action bar -->
    <style name="AppTheme.NoActionBar" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:windowBackground">@color/colorSplash</item>
        <item name="android:textColorPrimary">#0B3760</item>
        <item name="android:textColorSecondary">#2F4858</item>
        <item name="android:colorAccent">@color/colorAccent</item>
        <item name="colorAccent">@color/colorAccent</item>
        <item name="colorControlNormal">#0B3760</item>
        <item name="android:colorControlNormal">#0B3760</item>
        <item name="android:textColorPrimaryInverse">#FFFFFF</item>
        <item name="android:textColorHighlight">#5571CFC2</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:navigationBarColor">#FFFFFF</item>
        <item name="android:windowLightNavigationBar">true</item>
        <item name="android:forceDarkAllowed">false</item>
        <item name="actionModeStyle">@style/VetLearnActionMode</item>
        <item name="android:actionModeStyle">@style/VetLearnActionMode</item>
    </style>

    <!-- Make Android's native copy / paste toolbar readable in the WebView -->
    <style name="VetLearnActionMode" parent="Widget.AppCompat.ActionMode">
        <item name="background">@color/colorPrimary</item>
        <item name="android:background">@color/colorPrimary</item>
        <item name="titleTextStyle">@style/VetLearnActionModeTitle</item>
        <item name="subtitleTextStyle">@style/VetLearnActionModeSubtitle</item>
    </style>

    <style name="VetLearnActionModeTitle" parent="TextAppearance.AppCompat.Widget.ActionMode.Title">
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="VetLearnActionModeSubtitle" parent="TextAppearance.AppCompat.Widget.ActionMode.Subtitle">
        <item name="android:textColor">#E8F8F5</item>
    </style>

    <!-- Launch / splash screen theme -->
    <style name="AppTheme.NoActionBarLaunch" parent="Theme.SplashScreen">
        <item name="android:background">@color/colorSplash</item>
        <item name="android:windowBackground">@color/colorSplash</item>
        <item name="windowSplashScreenBackground">@color/colorSplash</item>
        <item name="postSplashScreenTheme">@style/AppTheme.NoActionBar</item>
    </style>

</resources>
