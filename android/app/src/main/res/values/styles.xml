<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base application theme -->
    <style name="AppTheme" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
        <item name="android:colorAccent">@color/colorAccent</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:navigationBarColor">#FFFFFF</item>
        <item name="android:windowLightNavigationBar">true</item>
        <item name="android:forceDarkAllowed">false</item>
        <item name="android:actionModeStyle">@style/VetLearnActionMode</item>
        <item name="actionModeStyle">@style/VetLearnActionMode</item>
        <item name="android:actionMenuTextColor">#0B3760</item>
        <item name="actionMenuTextColor">#0B3760</item>
        <item name="android:textColorPrimary">#0B3760</item>
        <item name="android:textColorSecondary">#2F4858</item>
        <item name="colorControlNormal">#0B3760</item>
        <item name="android:colorControlNormal">#0B3760</item>
    </style>

    <!-- Main app theme without action bar -->
    <style name="AppTheme.NoActionBar" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:windowBackground">@color/colorSplash</item>
        <item name="android:textColorPrimary">#0B3760</item>
        <item name="android:textColorSecondary">#2F4858</item>
        <item name="android:colorAccent">@color/colorAccent</item>
        <item name="colorAccent">@color/colorAccent</item>
        <item name="colorControlNormal">#0B3760</item>
        <item name="android:colorControlNormal">#0B3760</item>
        <item name="android:actionMenuTextColor">#0B3760</item>
        <item name="actionMenuTextColor">#0B3760</item>
        <item name="android:actionModeStyle">@style/VetLearnActionMode</item>
        <item name="actionModeStyle">@style/VetLearnActionMode</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:navigationBarColor">#FFFFFF</item>
        <item name="android:windowLightNavigationBar">true</item>
        <item name="android:forceDarkAllowed">false</item>
    </style>

    <style name="VetLearnActionMode" parent="@style/Widget.AppCompat.ActionMode">
        <item name="android:background">#FFFFFF</item>
        <item name="background">#FFFFFF</item>
        <item name="android:titleTextStyle">@style/VetLearnActionModeText</item>
        <item name="android:subtitleTextStyle">@style/VetLearnActionModeText</item>
        <item name="titleTextStyle">@style/VetLearnActionModeText</item>
        <item name="subtitleTextStyle">@style/VetLearnActionModeText</item>
    </style>

    <style name="VetLearnActionModeText" parent="@android:style/TextAppearance.Material.Widget.ActionMode.Title">
        <item name="android:textColor">#0B3760</item>
    </style>

    <!-- Launch / splash screen theme -->
    <style name="AppTheme.NoActionBarLaunch" parent="Theme.SplashScreen">
        <item name="android:background">@color/colorSplash</item>
        <item name="android:windowBackground">@color/colorSplash</item>
        <item name="windowSplashScreenBackground">@color/colorSplash</item>
        <item name="postSplashScreenTheme">@style/AppTheme.NoActionBar</item>
    </style>

</resources>
